{
  "name": "ohash",
  "version": "2.0.11",
  "description": "Simple object hashing, serialization and comparison utils.",
  "repository": "unjs/ohash",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./utils": "./dist/utils/index.mjs",
    "./crypto": {
      "node": "./dist/crypto/node/index.mjs",
      "default": "./dist/crypto/js/index.mjs"
    }
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "bench": "vitest bench",
    "build": "obuild",
    "dev": "vitest dev",
    "lint": "eslint . && prettier -c src test",
    "lint:fix": "automd && eslint --fix . && prettier -w src test",
    "prepack": "unbuild",
    "release": "pnpm test && changelogen --release --push && pnpm publish",
    "test": "pnpm lint && vitest run --coverage && pnpm test:types",
    "test:types": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "automd": "^0.4.3",
    "changelogen": "^0.6.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-unjs": "^0.6.2",
    "mitata": "^1.0.34",
    "obuild": "^0.4.36",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.4.0"
}